 // === BEGIN INSERTED CODE (end of load_all_data) ===

+#ifdef GGML_EOQ
+    if (n_eoq_decoded > 0) {
+        size_t total_compressed = 0;
+        size_t total_uncompressed = 0;
+        for (const auto & [name, info] : eoq_tensors) {
+            total_compressed   += info.on_disk_size;
+            total_uncompressed += info.header.uncompressed_size;
+        }
