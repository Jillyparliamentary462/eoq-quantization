 // =====================================================================
 // Modification to llama_tensor_weight constructor
 // =====================================================================
 //
 // The llama_tensor_weight constructor (in llama-model-loader.h, line
 // ~39) computes the tensor data offset and validates that the tensor
 // data fits within the file.  For EOQ tensors, the on-disk size
 // differs from ggml_nbytes(tensor) because by the time this
 // constructor runs, we have already changed the tensor's type back
 // to the original type (uncompressed).
 //
 // We must use the compressed size from GGUF for the bounds check.
 //
 // Location: in the llama_tensor_weight constructor, at the file
 // bounds validation (line ~46).

 // === BEGIN INSERTED CODE (llama_tensor_weight constructor) ===
 //
 // Replace the bounds check:
 //   if (offs + ggml_nbytes(tensor) < offs ||
 //       offs + ggml_nbytes(tensor) > file->size())
 //
 // With:

+    // Determine the on-disk size for this tensor.  For EOQ tensors,
+    // the on-disk size is the compressed size (stored in GGUF tensor
+    // info), which is smaller than ggml_nbytes(tensor) (the
+    // uncompressed in-memory size).
+    size_t n_bytes_on_disk = ggml_nbytes(tensor);
+
+#ifdef GGML_EOQ
+    if (gguf_get_tensor_type(gguf_ctx, tensor_idx) == GGML_TYPE_EOQ) {
