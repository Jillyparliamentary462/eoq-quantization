+// =====================================================================
+// EOQ helper: read per-tensor metadata from GGUF key-value pairs
+// =====================================================================
+//
+// This function is called for each tensor whose on-disk type is
+// GGML_TYPE_EOQ.  It reads the EOQ metadata stored by the converter
+// tool and populates an eoq_tensor_header_t.
+//
+// Returns the original GGML type, or GGML_TYPE_COUNT on error.
+//
+#ifdef GGML_EOQ
+static enum ggml_type eoq_read_tensor_metadata(
+        const struct gguf_context * gguf_ctx,
+        const char * tensor_name,
+        eoq_tensor_header_t * header)
+{
+    char key[512];
+
+    // Helper macro: look up a uint32 GGUF key, abort if missing.
+    #define EOQ_READ_U32(field, suffix) do {                               \
+        snprintf(key, sizeof(key), "eoq.tensor.%s." suffix, tensor_name); \
+        int64_t kid = gguf_find_key(gguf_ctx, key);                        \
+        if (kid < 0) {                                                     \
+            LLAMA_LOG_ERROR("%s: missing EOQ metadata key '%s'\n",         \
+                           __func__, key);                                 \
+            return GGML_TYPE_COUNT;                                        \
+        }                                                                  \
+        header->field = gguf_get_val_u32(gguf_ctx, kid);                   \
+    } while (0)
+
+    EOQ_READ_U32(original_type,      "original_type");
+    EOQ_READ_U32(num_blocks,         "num_blocks");
+    EOQ_READ_U32(freq_table_size,    "freq_table_size");
+    EOQ_READ_U32(precision_bits,     "precision_bits");
+    EOQ_READ_U32(rans_block_size,    "rans_block_size");
+    EOQ_READ_U32(compressed_size,    "compressed_size");
+    EOQ_READ_U32(uncompressed_size,  "uncompressed_size");
+
+    #undef EOQ_READ_U32
+
+    // Validate: original_type must be a real quantization type.
+    if (header->original_type >= GGML_TYPE_COUNT ||
+        header->original_type == GGML_TYPE_EOQ) {
+        LLAMA_LOG_ERROR("%s: tensor '%s' has invalid original_type %u\n",
+                       __func__, tensor_name, header->original_type);
+        return GGML_TYPE_COUNT;
+    }
+
+    LLAMA_LOG_DEBUG("%s: EOQ tensor '%s': original_type=%s (%u), "
+                   "compressed=%u -> uncompressed=%u bytes, "
+                   "precision=%u bits, alphabet=%u\n",
+                   __func__, tensor_name,
+                   ggml_type_name((enum ggml_type)header->original_type),
+                   header->original_type,
+                   header->compressed_size,
+                   header->uncompressed_size,
+                   header->precision_bits,
+                   header->freq_table_size);
+
+    return (enum ggml_type)header->original_type;
+}
+#endif // GGML_EOQ
+

 // =====================================================================
 // Modification to llama_model_loader constructor
@@ -XXX,6 +XXX,10 @@
 //
 // In the constructor body, inside the loop that populates weights_map
 // from the GGUF tensor info, we add EOQ detection.  The relevant loop
 // iterates over n_tensors and creates ggml_tensor objects.  When we
 // encounter a tensor with type GGML_TYPE_EOQ, we:
 //
 //   1. Read its EOQ metadata from GGUF KV pairs.
 //   2. Change the tensor's type to the original quant type.
 //   3. Recalculate ne[]/nb[] for the new type so that the tensor
 //      has the correct in-memory layout.
 //   4. Store the compressed on-disk size in eoq_tensors so that
 //      load_all_data() knows how many bytes to read.
 //
 // Pseudo-location: inside the constructor, in the ggml_context loop
 // that calls gguf_get_tensor_type() to initialize tensors from the
 // GGUF header.  The exact context differs between the files-based
 // path and the external-metadata path.
 //
 // In the files-based path (around line ~600-690 of the constructor),
 // after the tensor is initialized from GGUF info:
 //
 // ------------------------------------------------------------------

 // === BEGIN INSERTED CODE (in constructor, after tensor type is set) ===
 //
 // This block runs once for each tensor read from the GGUF file header.
 // Variable 'tensor' is the ggml_tensor* just created, and
 // 'metadata' is the gguf_context* for the file.

+#ifdef GGML_EOQ
+    if (tensor->type == GGML_TYPE_EOQ) {
+        const char * tname = ggml_get_name(tensor);
+
+        // Read all EOQ metadata from GGUF KV store.
+        eoq_tensor_info info;
+        memset(&info.header, 0, sizeof(info.header));
+
+        enum ggml_type orig_type = eoq_read_tensor_metadata(
+            metadata, tname, &info.header);
+
+        if (orig_type == GGML_TYPE_COUNT) {
+            throw std::runtime_error(
+                format("EOQ tensor '%s' has invalid or missing metadata", tname));
+        }
+
+        // Record the compressed on-disk size BEFORE we change the type.
+        // ggml_nbytes(tensor) while type==EOQ gives us the compressed size
+        // because blck_size=1 and type_size=1 for EOQ (from patch 02).
+        info.on_disk_size = ggml_nbytes(tensor);
+
+        // Change the tensor type to the original quantization type.
+        // This makes ggml_nbytes() return the UNCOMPRESSED size, which
+        // is what buffer allocation, graph construction, and inference
+        // all need.
+        tensor->type = orig_type;
+
+        // Recalculate nb[] (byte strides) for the new type.
+        // ne[] (element counts) remain the same -- the logical shape
+        // does not change, only the encoding.
+        tensor->nb[0] = ggml_type_size(orig_type);
+        for (int dim = 1; dim < GGML_MAX_DIMS; dim++) {
+            tensor->nb[dim] = tensor->nb[dim - 1] * tensor->ne[dim - 1];
+        }
+
+        // For block-quantized types, nb[0] should be type_size and
+        // ne[0] must be divisible by blck_size.  The GGUF file stores
+        // the logical element counts, so this should already be correct.
+        // We verify as a sanity check.
+        int64_t blck = ggml_blck_size(orig_type);
+        if (blck > 1) {
+            // For quantized types, nb[0] = type_size (size of one block)
+            // and ne[0] must be a multiple of blck_size.
+            tensor->nb[0] = ggml_type_size(orig_type);
+            // nb[1] = nb[0] * (ne[0] / blck_size)
+            tensor->nb[1] = tensor->nb[0] * (tensor->ne[0] / blck);
+            for (int dim = 2; dim < GGML_MAX_DIMS; dim++) {
+                tensor->nb[dim] = tensor->nb[dim - 1] * tensor->ne[dim - 1];
+            }
+        }
+
+        // Stash the EOQ info for load_all_data() to use later.
+        eoq_tensors[tname] = info;
+
+        LLAMA_LOG_INFO("%s: EOQ tensor '%s' -> %s, "
+                      "disk=%zu bytes, memory=%zu bytes (%.1f%% compression)\n",
+                      __func__, tname,
+                      ggml_type_name(orig_type),
+                      info.on_disk_size,
+                      (size_t)ggml_nbytes(tensor),
+                      100.0 * (1.0 - (double)info.on_disk_size / (double)ggml_nbytes(tensor)));
+    }
+#endif // GGML_EOQ

 // === END INSERTED CODE (constructor) ===


 // =====================================================================
 // Modification to llama_model_loader::load_all_data()
 // =====================================================================
 //
 // The main tensor data loading loop in load_all_data() iterates over
 // all tensors and copies data from the file (or mmap) into the
 // allocated tensor buffers.  For EOQ tensors, the on-disk data is
 // compressed and smaller than the in-memory buffer.
 //
 // We intercept the loading at line ~1505 of load_all_data(), inside
 // the per-tensor loop:
 //
 //   for (struct ggml_tensor * cur = ggml_get_first_tensor(ctx);
 //        cur != NULL;
 //        cur = ggml_get_next_tensor(ctx, cur))
 //
 // After "const auto * weight = get_weight(ggml_get_name(cur));" and
 // before the existing mmap/read logic, we check if this tensor was
 // originally EOQ and needs decompression.
 //
 // Key insight: By this point, cur->type has already been changed to
 // the original type (in the constructor).  So ggml_nbytes(cur) gives
 // the UNCOMPRESSED size.  But weight->offs and the file contain the
 // COMPRESSED data at the original offset.  We use the eoq_tensors
 // map to know (a) that this tensor needs decoding and (b) how many
 // compressed bytes to read.
 //
 // ------------------------------------------------------------------
 //
 // Insert this block at the beginning of the per-tensor loop body,
 // right after the weight==nullptr check and progress callback,
 // REPLACING the normal n_size / read / mmap logic for EOQ tensors:

 // === BEGIN INSERTED CODE (in load_all_data, inside per-tensor loop) ===
 //
 // Context: 'cur' is the current ggml_tensor*, 'weight' is the
 // llama_tensor_weight* with file offset info.

+#ifdef GGML_EOQ
+    {
+        auto eoq_it = eoq_tensors.find(ggml_get_name(cur));
+        if (eoq_it != eoq_tensors.end()) {
+            // This tensor was GGML_TYPE_EOQ on disk.  Decompress it.
+            const eoq_tensor_info & eoq_info = eoq_it->second;
+            const size_t compressed_size = eoq_info.on_disk_size;
+            const size_t uncompressed_size = ggml_nbytes(cur);
+
+            LLAMA_LOG_DEBUG("%s: decompressing EOQ tensor '%s': "
+                           "%zu -> %zu bytes\n",
+                           __func__, ggml_get_name(cur),
+                           compressed_size, uncompressed_size);
+
+            // Step 1: Read the compressed data from the file.
+            //
+            // We always read into a temporary buffer regardless of
+            // whether mmap is enabled, because we need to decompress
+            // before writing to the tensor.  (Mmap gives us a pointer
+            // to the compressed data which we could use directly, but
+            // we still need a separate output buffer.)
+
+            const uint8_t * compressed_data = nullptr;
+            std::vector<uint8_t> compressed_buf;
+
+            if (use_mmap) {
+                // With mmap, the data is already in memory.
+                const auto & mapping = mappings.at(weight->idx);
+                compressed_data = (const uint8_t *)mapping->addr() + weight->offs;
+            } else {
+                // Without mmap, read from file into a temporary buffer.
+                compressed_buf.resize(compressed_size);
+                const auto & file = files.at(weight->idx);
+                file->seek(weight->offs, SEEK_SET);
+                file->read_raw(compressed_buf.data(), compressed_size);
+                compressed_data = compressed_buf.data();
+            }
+
+            // Step 2: Allocate a temporary buffer for the decompressed
+            // output.  We decompress into this buffer first, then copy
+            // to the tensor's backend buffer (which may be on GPU).

+            std::vector<uint8_t> decompressed_buf(uncompressed_size);

+            // Step 3: Call the rANS decoder.
+            //
+            // eoq_decode_tensor() reads the freq table, block offsets,
+            // and compressed stream from the compressed_data pointer.
+            // It writes uncompressed_size bytes of standard quant
+            // block data to the output buffer.

+            int rc = eoq_decode_tensor(
+                &eoq_info.header,
+                compressed_data,
+                decompressed_buf.data());
+
+            if (rc != 0) {
+                throw std::runtime_error(
+                    format("failed to decompress EOQ tensor '%s'",
+                           ggml_get_name(cur)));
+            }

+            // Step 4: Validate the decompressed data (if enabled).

+            if (check_tensors) {
+                if (!ggml_validate_row_data(cur->type,
+                                            decompressed_buf.data(),
+                                            uncompressed_size)) {
+                    throw std::runtime_error(
+                        format("tensor '%s' has invalid data after "
+                               "EOQ decompression", ggml_get_name(cur)));
+                }
+            }

+            // Step 5: Copy decompressed data to the tensor's buffer.
+            //
+            // ggml_backend_tensor_set handles the case where the tensor
+            // is on a non-host backend (e.g., GPU) by performing the
+            // appropriate host->device transfer.

+            if (use_mmap) {
+                // For mmap, the tensor may not have a buffer allocated
+                // yet.  Allocate it first using the decompressed data.
+                ggml_backend_buffer_t buf_mmap = nullptr;
+                if (bufs.count(weight->idx)) {
+                    buf_mmap = bufs.at(weight->idx);
+                }
+                if (buf_mmap && cur->data == nullptr) {
+                    // We cannot use ggml_backend_tensor_alloc with the
+                    // mmap pointer because it points to compressed data.
+                    // Allocate with a dummy, then overwrite.
+                    ggml_backend_tensor_alloc(buf_mmap, cur,
+                        (void *)compressed_data);
+                }
+                // Now overwrite with decompressed data.
+                ggml_backend_tensor_set(cur, decompressed_buf.data(),
+                                        0, uncompressed_size);
+            } else {
+                if (ggml_backend_buffer_is_host(cur->buffer)) {
+                    // Direct copy for host buffers.
+                    memcpy(cur->data, decompressed_buf.data(),
+                           uncompressed_size);
+                } else {
+                    // For device buffers, use the backend transfer API.
+                    ggml_backend_tensor_set(cur, decompressed_buf.data(),
+                                            0, uncompressed_size);
+                }
+            }

+            // Update mmap tracking if applicable.
+            if (use_mmap) {
+                auto & mmap_used = mmaps_used[weight->idx];
+                mmap_used.first  = std::min(mmap_used.first,  weight->offs);
+                mmap_used.second = std::max(mmap_used.second,
+                                            weight->offs + compressed_size);
+            }

+            // Account for the on-disk size in the progress counter.
+            // We add compressed_size (not uncompressed) because
+            // size_data was computed from the on-disk file layout.
+            size_done += compressed_size;
+            n_eoq_decoded++;

+            // Skip the normal (non-EOQ) loading code below.
+            continue;
+        }
+    }
+#endif // GGML_EOQ

 // === END INSERTED CODE (load_all_data) ===
 //
 // After this continue, the normal mmap/read code path runs for
 // non-EOQ tensors exactly as before.  No existing behavior is changed.


