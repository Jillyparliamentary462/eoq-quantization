HUNK 3b: Add the rANS encoder function (encode-side, only needed at quantize time)
------------------------------------------------------------------------------------

Insert before llama_model_quantize_impl():

--- a/src/llama-quant.cpp
+++ b/src/llama-quant.cpp
@@ -XXX,6 +XXX,140 @@

+#ifdef GGML_EOQ
+// =========================================================================
+// EOQ rANS Encoder -- used only at quantize-time to produce compressed GGUF
+// =========================================================================
+//
+// This is a straightforward single-stream rANS encoder. Performance is
+// not critical here (runs once offline), so we favor clarity over speed.
+// The wire format is identical to what eoq_decode_tensor_v2() expects.
+
+struct eoq_encode_result {
+    std::vector<uint8_t> data;           // complete blob: header + freq_table + block_offsets + compressed
+    eoq_tensor_header_t  header;         // also returned separately for convenience
+    double               compression_ratio;
+};
+
+// Count byte frequencies in a raw tensor blob.
+static void eoq_count_frequencies(
+    const uint8_t * data,
+    size_t          data_size,
+    uint64_t        freq_raw[256])
+{
+    memset(freq_raw, 0, 256 * sizeof(uint64_t));
+    for (size_t i = 0; i < data_size; ++i) {
+        freq_raw[data[i]]++;
+    }
+}
+
+// Normalize raw counts to sum to M = 1 << precision_bits.
+// Every symbol present in the input gets at least frequency 1.
+// Returns the normalized freq table as uint16_t[256].
+static void eoq_normalize_freq(
+    const uint64_t  raw[256],
+    uint32_t        precision_bits,
+    uint16_t        norm[256])
+{
+    const uint32_t M = 1u << precision_bits;
+    uint64_t total = 0;
+    for (int i = 0; i < 256; ++i) total += raw[i];
+    if (total == 0) {
+        // Degenerate: no data. Uniform distribution.
+        for (int i = 0; i < 256; ++i) norm[i] = M / 256;
+        norm[0] += M - 256 * (M / 256);  // fixup remainder
+        return;
+    }
+
+    uint32_t assigned = 0;
+    int n_nonzero = 0;
+    for (int i = 0; i < 256; ++i) {
+        if (raw[i] > 0) {
+            norm[i] = (uint16_t)std::max(1u, (uint32_t)((raw[i] * M) / total));
+            n_nonzero++;
+        } else {
+            norm[i] = 0;
+        }
+        assigned += norm[i];
+    }
+
+    // Adjust the largest-frequency symbol to make the sum exactly M.
+    int max_idx = 0;
+    for (int i = 1; i < 256; ++i) {
+        if (norm[i] > norm[max_idx]) max_idx = i;
+    }
+    if (assigned < M) {
+        norm[max_idx] += (M - assigned);
+    } else if (assigned > M) {
+        // Should not underflow below 1 for the max symbol.
+        uint32_t excess = assigned - M;
+        if (norm[max_idx] > excess + 1) {
+            norm[max_idx] -= (uint16_t)excess;
+        } else {
+            // Spread the reduction across multiple symbols (rare edge case).
+            for (int i = 0; i < 256 && excess > 0; ++i) {
+                if (norm[i] > 1) {
+                    uint16_t reduce = (uint16_t)std::min((uint32_t)(norm[i] - 1), excess);
+                    norm[i] -= reduce;
+                    excess -= reduce;
+                }
+            }
+        }
+    }
+}
+
+// Single-stream rANS encode of a byte buffer.
+// Produces the wire-format blob that eoq_decode_tensor_v2() consumes.
+//
+// Wire format for the entire tensor:
+//   eoq_tensor_header_t  (28 bytes)
+//   uint16_t freq_table[256]  (512 bytes)
+//   uint32_t block_offsets[num_rans_blocks]
+//   compressed stream bytes (all blocks concatenated)
+//
+static eoq_encode_result eoq_encode_tensor(
+    const uint8_t * tensor_data,
+    size_t          tensor_size,
+    uint32_t        original_ggml_type,
+    uint32_t        precision_bits,
+    uint32_t        rans_block_size)
+{
+    eoq_encode_result result = {};
+
+    // Step 1: Compute byte-level frequency table for this tensor.
+    uint64_t freq_raw[256];
+    eoq_count_frequencies(tensor_data, tensor_size, freq_raw);
+
+    uint16_t freq_norm[256];
+    eoq_normalize_freq(freq_raw, precision_bits, freq_norm);
+
+    // Build CDF from normalized frequencies.
+    uint32_t cdf[257];
+    cdf[0] = 0;
+    for (int i = 0; i < 256; ++i) {
+        cdf[i + 1] = cdf[i] + freq_norm[i];
+    }
+
+    // Step 2: Divide input into rANS blocks and encode each.
+    const uint32_t num_blocks = (uint32_t)((tensor_size + rans_block_size - 1) / rans_block_size);
+    const uint32_t M = 1u << precision_bits;
+    const uint32_t RANS_L = M << 8;  // lower bound of rANS state interval
+
+    // We'll collect per-block compressed data, then assemble the final blob.
+    std::vector<std::vector<uint8_t>> block_streams(num_blocks);
+
+    for (uint32_t blk = 0; blk < num_blocks; ++blk) {
+        size_t blk_start = (size_t)blk * rans_block_size;
+        size_t blk_end   = std::min(blk_start + rans_block_size, tensor_size);
+        size_t blk_len   = blk_end - blk_start;
+
+        // rANS encoding processes symbols in REVERSE order.
+        // The renormalization bytes are emitted into a buffer that will be
+        // reversed at the end to produce the forward-readable stream.
+        std::vector<uint8_t> renorm_buf;
+        renorm_buf.reserve(blk_len * 2);  // generous upper bound
+
+        uint32_t state = RANS_L;
+
+        for (size_t j = blk_len; j-- > 0; ) {
+            uint8_t sym = tensor_data[blk_start + j];
+            uint32_t freq = freq_norm[sym];
+            uint32_t cum  = cdf[sym];
+
+            // Renormalize: while state >= freq * (RANS_L >> precision_bits) * 256,
+            // emit one byte from the low bits of state.
+            // Equivalently: state >= freq << (precision_bits + 8)  won't work for
+            // large precision_bits, so use the standard check:
+            uint32_t upper = ((RANS_L >> precision_bits) << 8) * freq;
+            while (state >= upper) {
+                renorm_buf.push_back((uint8_t)(state & 0xFF));
+                state >>= 8;
+            }
+
+            // rANS encode step:
+            //   state = (state / freq) * M + (state % freq) + cum
+            state = ((state / freq) << precision_bits) + (state % freq) + cum;
+        }
+
+        // Serialize final state + renorm stream.
+        // Wire format per block:
+        //   1 byte:  state_len (how many bytes encode the final state)
+        //   state_len bytes:  state (big-endian)
+        //   remaining bytes:  renormalization stream (reversed from renorm_buf)
+        std::vector<uint8_t> block_data;
+
+        // Encode state in big-endian, variable length.
+        uint8_t state_bytes[8];
+        int state_len = 0;
+        {
+            uint32_t s = state;
+            do {
+                state_bytes[state_len++] = (uint8_t)(s >> 24);
+                s <<= 8;
+            } while (s != 0 && state_len < 4);
+        }
+        block_data.push_back((uint8_t)state_len);
+        for (int k = 0; k < state_len; ++k) {
+            block_data.push_back(state_bytes[k]);
+        }
+
+        // Reverse renorm_buf to get forward-readable stream.
+        for (size_t k = renorm_buf.size(); k-- > 0; ) {
+            block_data.push_back(renorm_buf[k]);
+        }
+
+        block_streams[blk] = std::move(block_data);
+    }
+
+    // Step 3: Assemble the final blob.
+    //   header | freq_table | block_offsets | block_data...
+    size_t compressed_payload_size = 0;
+    for (auto & bs : block_streams) compressed_payload_size += bs.size();
+
+    size_t meta_size = sizeof(eoq_tensor_header_t) + 256 * sizeof(uint16_t) + num_blocks * sizeof(uint32_t);
+    size_t total_blob_size = meta_size + compressed_payload_size;
+
+    result.data.resize(total_blob_size);
+    uint8_t * out = result.data.data();
+
+    // Fill header.
+    eoq_tensor_header_t hdr = {};
+    hdr.original_type     = original_ggml_type;
+    hdr.num_blocks        = num_blocks;
+    hdr.freq_table_size   = EOQ_ALPHABET_SIZE;
+    hdr.precision_bits    = precision_bits;
+    hdr.rans_block_size   = rans_block_size;
+    hdr.compressed_size   = (uint32_t)total_blob_size;
+    hdr.uncompressed_size = (uint32_t)tensor_size;
+
+    memcpy(out, &hdr, sizeof(hdr));
+    out += sizeof(hdr);
+
+    // Frequency table.
+    memcpy(out, freq_norm, 256 * sizeof(uint16_t));
+    out += 256 * sizeof(uint16_t);
+
+    // Block offsets (byte offset of each block within the compressed payload area).
+    uint32_t running_offset = 0;
+    for (uint32_t blk = 0; blk < num_blocks; ++blk) {
+        uint32_t off = running_offset;
+        memcpy(out, &off, sizeof(uint32_t));
+        out += sizeof(uint32_t);
+        running_offset += (uint32_t)block_streams[blk].size();
+    }
+
+    // Block data.
+    for (uint32_t blk = 0; blk < num_blocks; ++blk) {
+        memcpy(out, block_streams[blk].data(), block_streams[blk].size());
+        out += block_streams[blk].size();
+    }
+
+    result.header = hdr;
+    result.compression_ratio = (tensor_size > 0) ? (double)total_blob_size / (double)tensor_size : 1.0;
+
+    return result;
+}
+
+// Determine whether a tensor is eligible for EOQ compression.
+// We compress quantized weight tensors but skip:
+//   - Already-EOQ tensors
+//   - F32/F16/BF16 tensors (small count, not worth compressing)
+//   - 1-D tensors (biases, norms -- tiny, not worth it)
+static bool eoq_tensor_eligible(const ggml_tensor * tensor) {
+    if (tensor->type == GGML_TYPE_EOQ)  return false;
+    if (tensor->type == GGML_TYPE_F32)  return false;
+    if (tensor->type == GGML_TYPE_F16)  return false;
+    if (tensor->type == GGML_TYPE_BF16) return false;
+    if (ggml_n_dims(tensor) < 2)        return false;
+    return ggml_is_quantized(tensor->type);
+}
+#endif  // GGML_EOQ


